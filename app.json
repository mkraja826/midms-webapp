{
  "expo": {
    "name": "CapDent",
    "slug": "capdent-webapp",
    "scheme": "capdent",
    "version": "1.2.0",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "CapDent uses the camera for patient photos, prescriptions, X-rays, and clinical images.",
          "photosPermission": "CapDent uses selected images for patient photos, prescriptions, X-rays, and reports."
        }
      ],
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "CapDent",
      "shortName": "CapDent",
      "lang": "en",
      "themeColor": "#0F766E",
      "backgroundColor": "#F7FAFC"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    },
    "owner": "mk261098s-team"
  }
}
