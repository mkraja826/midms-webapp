# CapDent Web environment
# Copy this file to .env and replace the placeholders.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# CapDent automatically uses the current browser origin when these are omitted.
# EXPO_PUBLIC_AUTH_CALLBACK_URL=https://your-domain.example/auth/callback
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://your-domain.example/auth/reset-password

EXPO_PUBLIC_ENABLE_REALTIME=true
EXPO_PUBLIC_UPLOAD_PROVIDER=supabase
EXPO_PUBLIC_UPLOAD_STRICT_R2=false
