EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Optional: legacy projects can use EXPO_PUBLIC_SUPABASE_ANON_KEY instead.
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Deep link opened by Supabase password recovery emails.
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=dms://auth/reset-password

# Release feature flags. Keep disabled until separately tested and approved.
EXPO_PUBLIC_ENABLE_PAID_PLANS=false
EXPO_PUBLIC_ENABLE_REALTIME=true

# Clinical uploads use Cloudflare R2 with a Supabase Storage fallback.
EXPO_PUBLIC_UPLOAD_PROVIDER=r2
EXPO_PUBLIC_UPLOAD_STRICT_R2=false
