EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Optional: legacy projects can use EXPO_PUBLIC_SUPABASE_ANON_KEY instead.
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Deep link opened by Supabase password recovery emails.
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=dms://auth/reset-password

