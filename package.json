{
  "name": "capdent-webapp",
  "version": "1.2.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "prepare:web": "node scripts/prepare-web-source.mjs && node scripts/patch-web-auth-route.mjs && node scripts/patch-v18-waiting.mjs && node scripts/setup-web-env.mjs",
    "setup:web": "npm run prepare:web",
    "normalize:lock": "node scripts/normalize-package-lock.mjs",
    "prestart": "npm run prepare:web",
    "start": "expo start --web",
    "preweb": "npm run prepare:web",
    "web": "expo start --web",
    "preweb:clear": "npm run prepare:web",
    "web:clear": "expo start --web --clear",
    "prebuild:web": "npm run prepare:web",
    "build:web": "expo export --platform web",
    "preview:web": "npx serve dist",
    "pretypecheck": "npm run prepare:web",
    "typecheck": "tsc --noEmit",
    "check:web": "npm run typecheck && npm run build:web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-file-system": "^57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-status-bar": "^57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  }
}
