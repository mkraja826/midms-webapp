    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-status-bar": "^57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-safe-area-context": "~5.7.0",
